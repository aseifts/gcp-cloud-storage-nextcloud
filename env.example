# Database Secrets
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_PASSWORD=your_nextcloud_db_password_here

# GCP Cloud Storage (HMAC Keys)
GCS_BUCKET_NAME=your-unique-bucket-name
GCS_ACCESS_KEY=GOOG1234567890EXAMPLE
GCS_SECRET_KEY=your_secret_hmac_key_here

# Nextcloud Admin Account
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=your_admin_password_here
